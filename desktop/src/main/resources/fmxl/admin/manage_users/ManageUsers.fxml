<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<fx:root type="VBox" stylesheets="@/css/manageUsers.css" styleClass="page" xmlns:fx="http://javafx.com/fxml">

    <HBox spacing="15" alignment="CENTER_LEFT">
        <Button onAction="#handleBack" styleClass="icon-btn">
            <graphic>
                <FontIcon iconLiteral="ion4-ios-arrow-round-back" iconSize="26" iconColor="#475569" mouseTransparent="true"/>
            </graphic>
        </Button>
        <VBox spacing="2">
            <Label text="Beheer gebruikers" styleClass="page-title"/>
            <Label text="Details van het personeel wijzigen." styleClass="page-subtitle"/>
        </VBox>
    </HBox>

    <Label fx:id="foutLabel" styleClass="error-label" visible="false" managed="false" text="" style="-fx-text-fill: #e31b35; -fx-font-weight: bold;"/>

    <VBox styleClass="modern-table-container" VBox.vgrow="ALWAYS" spacing="15">

        <HBox spacing="15" alignment="CENTER_LEFT">
            <TextField fx:id="zoekField" promptText="Zoek op naam, email..." styleClass="modern-input" prefWidth="350"/>
            <Region HBox.hgrow="ALWAYS" /> <Label text="Filter:" style="-fx-text-fill: #64748b; -fx-font-weight: bold;"/>
            <ComboBox fx:id="statusFilterBox" promptText="Filter op status" styleClass="modern-input" prefWidth="180"/>
        </HBox>

        <TableView fx:id="gebruikersTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="naamCol" text="NAAM" prefWidth="140"/>
                <TableColumn fx:id="voornaamCol" text="VOORNAAM" prefWidth="140"/>
                <TableColumn fx:id="emailCol" text="EMAILADRES" prefWidth="250"/>
                <TableColumn fx:id="rolCol" text="ROL" prefWidth="150"/>
                <TableColumn fx:id="statusCol" text="STATUS" prefWidth="150"/>
                <TableColumn fx:id="telefoonCol" text="TELEFOON" prefWidth="140"/>
            </columns>
        </TableView>

    </VBox>

</fx:root>
