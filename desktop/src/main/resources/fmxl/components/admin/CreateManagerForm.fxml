<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>

<?import org.kordamp.ikonli.javafx.FontIcon?>
<fx:root type="VBox" styleClass="create-form-wrapper" xmlns:fx="http://javafx.com/fxml"
         stylesheets="@/css/create-manager.css">

    <HBox styleClass="form-back-btn-row">
        <Button fx:id="backBtn" styleClass="back-btn">
            <FontIcon iconLiteral="ion4-ios-arrow-round-back" iconSize="16" mouseTransparent="true"/>
        </Button>
    </HBox>

    <Label text="Create Manager" styleClass="form-title"/>

    <Label text="Personal Info:" styleClass="form-section-label"/>

    <TextField fx:id="idField" promptText="id" styleClass="form-input"/>
    <TextField fx:id="nameField" promptText="name" styleClass="form-input"/>
    <TextField fx:id="surnameField" promptText="surname" styleClass="form-input"/>
    <TextField fx:id="phoneField" promptText="phone" styleClass="form-input"/>
    <TextField fx:id="emailField" promptText="email" styleClass="form-input"/>

    <Label text="Availability:" styleClass="form-section-label"/>

    <TextField fx:id="availabilityField" promptText="availability" styleClass="form-input"/>
    <TextField fx:id="plantField" promptText="plant" styleClass="form-input"/>

    <Button fx:id="createBtn" text="create a manager" styleClass="form-submit-btn"/>
    <Label fx:id="loginLink" text="login" styleClass="form-login-link"/>

</fx:root>
