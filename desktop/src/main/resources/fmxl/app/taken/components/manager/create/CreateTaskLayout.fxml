<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<fx:root type="VBox" xmlns:fx="http://javafx.com/fxml" styleClass="modal-card" spacing="16" maxHeight="-Infinity" stylesheets="@/css/tasks.css">
    <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>

    <HBox alignment="CENTER_LEFT">
        <VBox spacing="2">
            <Label text="Nieuwe taak aanmaken" styleClass="card_title" style="-fx-font-size: 18px;"/>
            <Label text="Plan de taak in en koppel een locatie." styleClass="page-subtitle"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="cancelButton" text="✕" styleClass="close-icon-btn"/>
    </HBox>

    <Separator styleClass="form-separator"/>

    <VBox spacing="6">
        <Label text="TAAKOMSCHRIJVING" styleClass="field-group-label"/>
        <TextField fx:id="nameField" promptText="Bv. Inspectie machine C" styleClass="modern-input"/>
    </VBox>

    <VBox spacing="6">
        <Label text="SPECIFICATIES" styleClass="field-group-label"/>
        <TextArea fx:id="specField" promptText="Extra opmerkingen..." prefRowCount="2" styleClass="modern-input-area" wrapText="true"/>
    </VBox>

    <VBox spacing="6">
        <Label text="LOCATIE" styleClass="field-group-label"/>
        <ComboBox fx:id="locationPicker" promptText="Kies site..." maxWidth="Infinity" styleClass="modern-combo-box"/>
    </VBox>

    <GridPane hgap="16" vgap="12">
        <columnConstraints>
            <ColumnConstraints percentWidth="50"/>
            <ColumnConstraints percentWidth="50"/>
        </columnConstraints>

        <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="0">
            <Label text="Startdatum" styleClass="field-sub-label"/>
            <DatePicker fx:id="startDatePicker" maxWidth="Infinity" styleClass="modern-date-picker"/>
        </VBox>
        <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="1">
            <Label text="Startuur" styleClass="field-sub-label"/>
            <HBox spacing="4" alignment="CENTER_LEFT">
                <ComboBox fx:id="startHourPicker" styleClass="modern-combo-box" prefWidth="100"/>
                <Label text=":" style="-fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                <ComboBox fx:id="startMinutePicker" styleClass="modern-combo-box" prefWidth="100"/>
            </HBox>
        </VBox>

        <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="0">
            <Label text="Deadline (Einddatum)" styleClass="field-sub-label"/>
            <DatePicker fx:id="dueDatePicker" maxWidth="Infinity" styleClass="modern-date-picker"/>
        </VBox>
        <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="1">
            <Label text="Einduur" styleClass="field-sub-label"/>
            <HBox spacing="4" alignment="CENTER_LEFT">
                <ComboBox fx:id="endHourPicker" styleClass="modern-combo-box" prefWidth="100"/>
                <Label text=":" style="-fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                <ComboBox fx:id="endMinutePicker" styleClass="modern-combo-box" prefWidth="100"/>
            </HBox>
        </VBox>
    </GridPane>

    <VBox spacing="10" alignment="CENTER">
        <VBox.margin><Insets top="8"/></VBox.margin>
        <Button fx:id="createButton" text="Taak Aanmaken" styleClass="create-task-btn" maxWidth="Infinity"/>
        <Label fx:id="feedbackLabel" visible="false" managed="false" wrapText="true"/>
    </VBox>

</fx:root>
