<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.geometry.Insets?>
<?import javafx.collections.FXCollections?>
<?import javafx.scene.shape.Rectangle?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<fx:root type="VBox" xmlns:fx="http://javafx.com/fxml" styleClass="task_root" stylesheets="@/css/locaties.css" VBox.vgrow="ALWAYS">
    <GridPane hgap="10" vgap="10" VBox.vgrow="ALWAYS">
        <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
        <columnConstraints>
            <ColumnConstraints percentWidth="70"/>
            <ColumnConstraints percentWidth="30"/>
        </columnConstraints>
        <rowConstraints>
            <RowConstraints vgrow="ALWAYS" fillHeight="true"/>
        </rowConstraints>

        <VBox VBox.vgrow="ALWAYS" fx:id="leftCard" GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="card">

            <HBox styleClass="card_header" alignment="CENTER_LEFT">
                <padding><Insets top="5" right="25" bottom="5" left="25"/></padding>
                <Label text="Alle locaties" fx:id="page_title" styleClass="page_title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox alignment="CENTER" spacing="15">
                    <TextField fx:id="zoekField" promptText="Zoek op naam of locatie..." prefWidth="300" styleClass="search-field"/>
                    <ComboBox fx:id="statusDropdown" value="Status" styleClass="picker"/>
                </HBox>
            </HBox>

            <TableView fx:id="locatieTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="naamCol" text="Naam" prefWidth="120"/>
                    <TableColumn fx:id="locatieCol" text="Locatie" prefWidth="200"/>
                    <TableColumn fx:id="capCol" text="Capaciteit" prefWidth="100"/>
                    <TableColumn fx:id="statusCol" text="Status" prefWidth="100"/>
                </columns>
            </TableView>

            <HBox spacing="10" alignment="CENTER_LEFT" styleClass="card_footer">
                <padding><Insets top="15" right="20" bottom="15" left="20"/></padding>

                <Button fx:id="btnNieuw" text="+ Maak site aan" onAction="#handleNieuw" styleClass="btn-success" minWidth="-Infinity"/>
                <Button fx:id="btnWijzig" text="Wijzig site" onAction="#handleWijzig" disable="true" styleClass="btn-secondary" minWidth="-Infinity"/>
                <Button fx:id="btnAnnuleerSite" text="Annuleer" onAction="#handleAnnuleerSite" visible="false" managed="false" styleClass="btn-secondary" minWidth="-Infinity"/>
                <Button fx:id="btnVerwijder" text="Verwijder site" onAction="#handleVerwijder" disable="true" styleClass="btn-danger" minWidth="-Infinity"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Button fx:id="btnMaakMachine" text="+ Creëer machine" onAction="#handleMaakMachine" disable="true" styleClass="btn-success" minWidth="-Infinity"/>
            </HBox>

        </VBox>

        <VBox VBox.vgrow="ALWAYS" fx:id="rightCard" GridPane.columnIndex="1" GridPane.rowIndex="0" styleClass="card">

            <HBox styleClass="card_header" spacing="15" alignment="CENTER_LEFT">
                <padding><Insets top="5" right="25" bottom="5" left="25"/></padding>
                <FontIcon iconLiteral="mdal-location_on" iconSize="25" iconColor="#E31B35"/>
                <VBox alignment="CENTER_LEFT">
                    <Label text="Locatie Details" styleClass="location_title"/>
                    <Label text="Info en Machines" styleClass="location_subtitle"/>
                </VBox>
            </HBox>

            <VBox spacing="15" VBox.vgrow="ALWAYS">
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

                <Label fx:id="lblSiteError" text=" " minHeight="40" wrapText="true" style="-fx-text-fill: #E31B35; -fx-font-weight: bold;"/>

                <Label text="Site-info" style="-fx-font-weight: bold; -fx-font-size: 16px;"/>

                <VBox spacing="5">
                    <Label fx:id="lblDetailNaam" text="Selecteer een locatie..." style="-fx-font-size: 14px;"/>
                    <TextField fx:id="txtDetailNaam" promptText="naam..." visible="false" managed="false" styleClass="form-control"/>
                </VBox>

                <VBox spacing="5">
                    <Label fx:id="lblDetailLocatie" text="-" wrapText="true"/>
                    <TextField fx:id="txtDetailLocatie" promptText="locatie/adres..." visible="false" managed="false" styleClass="form-control"/>
                </VBox>

                <VBox spacing="5">
                    <Label fx:id="lblDetailCapaciteit" text="-"/>
                    <TextField fx:id="txtDetailCapaciteit" promptText="capaciteit..." visible="false" managed="false" styleClass="form-control"/>
                </VBox>

                <Label text="Status" style="-fx-font-weight: bold; -fx-font-size: 16px;">
                    <VBox.margin><Insets top="10"/></VBox.margin>
                </Label>

                <VBox spacing="5">
                    <Label fx:id="lblDetailStatus" text="-"/>
                    <ComboBox fx:id="cmbDetailStatus" value="status" styleClass="form-control" visible="false" managed="false" prefWidth="150"/>
                </VBox>

                <Label text="Gekoppelde Machines" style="-fx-font-weight: bold; -fx-font-size: 16px;">
                    <VBox.margin><Insets top="10"/></VBox.margin>
                </Label>

                <ListView fx:id="listMachines" VBox.vgrow="ALWAYS" prefHeight="100" styleClass="machine-list"/>
            </VBox>

            <HBox spacing="10" alignment="CENTER_RIGHT" styleClass="card_footer">
                <padding><Insets top="15" right="20" bottom="15" left="20"/></padding>
                <Button fx:id="btnWijzigMachine" text="Wijzig machine" onAction="#handleWijzigMachine" disable="true" styleClass="btn-secondary" minWidth="-Infinity"/>
                <Button fx:id="btnVerwijderMachine" text="Verwijder machine" onAction="#handleVerwijderMachine" disable="true" styleClass="btn-danger" minWidth="-Infinity"/>
            </HBox>

        </VBox>

    </GridPane>
</fx:root>