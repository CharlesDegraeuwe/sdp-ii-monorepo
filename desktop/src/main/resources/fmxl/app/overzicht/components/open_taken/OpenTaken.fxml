<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<fx:root type="VBox" fx:id="container" spacing="10" xmlns:fx="http://javafx.com/fxml">
    <padding>
    </padding>
    <HBox alignment="CENTER_LEFT" spacing="8">
        <Label text="Open taken:" styleClass="section_label"/>
        <Region HBox.hgrow="ALWAYS"/>
        <ComboBox fx:id="teamPicker" value="Team A" styleClass="team_picker"/>
    </HBox>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" maxHeight="200" VBox.vgrow="ALWAYS">
        <VBox fx:id="itemContainer" spacing="7"/>
    </ScrollPane>
    <HBox alignment="CENTER_RIGHT">
        <Button text="meer" fx:id="see_more" styleClass="see_more_button"/>
    </HBox>
</fx:root>