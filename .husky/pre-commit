#!/bin/sh

set -e

ROOT="$(git rev-parse --show-toplevel)"

echo "🔍 Running lint-staged for web..."
cd "$ROOT/web" && bunx lint-staged

if git diff --cached --name-only | grep -q "^api/"; then
  echo "🧪 Running Maven tests for api..."
  cd "$ROOT/api" && ./mvnw test -q
fi

if git diff --cached --name-only | grep -q "^desktop/"; then
  echo "🧪 Running Maven tests for desktop..."
  cd "$ROOT/desktop" && ./mvnw test -q
fi

echo "✅ Pre-commit checks passed."
