<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>

<?import org.kordamp.ikonli.javafx.FontIcon?>
<?import javafx.scene.control.DatePicker?>
<fx:root type="VBox" styleClass="create-form-wrapper" xmlns:fx="http://javafx.com/fxml"
         stylesheets="@/css/create-manager.css">

    <HBox styleClass="form-back-btn-row">
        <Button fx:id="backBtn" styleClass="back-btn" onAction="#handleBack">
            <graphic>
                <FontIcon iconLiteral="ion4-ios-arrow-round-back" iconSize="16" mouseTransparent="true"/>
            </graphic>
        </Button>
    </HBox>


    <Label text="Creëer Manager" styleClass="form-title"/>

    <Label text="Persoonlijke Info:" styleClass="form-section-label"/>

    <TextField fx:id="nameField" promptText="naam" styleClass="form-input"/>
    <TextField fx:id="surnameField" promptText="voornaam" styleClass="form-input"/>
    <DatePicker fx:id="dobField" promptText="geboortedatum" styleClass="form-input"/>
    <TextField fx:id="phoneField" promptText="gsm" styleClass="form-input"/>
    <TextField fx:id="emailField" promptText="email" styleClass="form-input"/>


    <Label fx:id="feedbackLabel" text="" style="-fx-font-weight: bold;" wrapText="true"/>
    <Button text="Creëer manager" onAction="#handleRegistreerManager" styleClass="form-submit-btn"/>

</fx:root>
