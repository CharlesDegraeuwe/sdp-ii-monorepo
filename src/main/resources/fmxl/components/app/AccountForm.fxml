<?xml version="1.0" encoding="UTF-8"?>

        <?import java.lang.*?>
        <?import java.util.*?>
        <?import javafx.scene.*?>
        <?import javafx.scene.control.*?>
        <?import javafx.scene.layout.*?>

<fx:root type="VBox" styleClass="account-page" xmlns:fx="http://javafx.com/fxml">
<VBox styleClass="account-card">
    <Label text="Account informatie" styleClass="account-title"/>
    <TextField fx:id="txtNaam" promptText="naam"/>
    <TextField fx:id="txtVoornaam" promptText="voornaam"/>
    <TextField fx:id="txtEmail" promptText="email"/>
    <PasswordField fx:id="txtWachtwoord" promptText="password"/>
    <TextField fx:id="txtTelefoonnummer" promptText="telefoonnummer"/>
    <TextField fx:id="txtGeboortedatum" promptText="geboortedatum" />
    <Button text="wijzig accountgegevens" onAction="#veranderAccount" maxWidth="Infinity" styleClass="account-btn"/>
</VBox>
</fx:root>



