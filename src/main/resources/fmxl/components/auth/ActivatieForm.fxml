<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>

<fx:root type="VBox" spacing="15" alignment="CENTER" stylesheets="@/css/dashboard.css" styleClass="page" xmlns:fx="http://javafx.com/fxml">

    <padding>
        <Insets top="40" right="40" bottom="40" left="40"/>
    </padding>

    <Label text="Account Activeren" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
    <Label text="Vul je 6-cijferige activatiecode in om door te gaan."/>

    <Label fx:id="lblBericht" text="" style="-fx-text-fill: red;"/>

    <TextField fx:id="txtCode" promptText="Bijv. 123456" maxWidth="200" alignment="CENTER"/>

    <HBox spacing="10" alignment="CENTER">
        <Button fx:id="btnActiveer" text="Activeer Account" onAction="#handleActiveer" styleClass="btn-succes"/>
    </HBox>

</fx:root>