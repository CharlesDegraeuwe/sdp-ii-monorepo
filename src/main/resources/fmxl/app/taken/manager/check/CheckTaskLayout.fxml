<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.geometry.Insets?>
<?import javafx.collections.FXCollections?>
<fx:root type="BorderPane" xmlns:fx="http://javafx.com/fxml">

    <center>
        <VBox spacing="12" VBox.vgrow="ALWAYS">

            <HBox alignment="CENTER" spacing="10" minHeight="20">
                <ComboBox fx:id="Toegewezen" value="Toegewezen" styleClass="picker">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <String fx:value="Toegewezen"/>
                            <String fx:value="Niet toegewezen"/>
                        </FXCollections>
                    </items>
                </ComboBox>
                <ComboBox fx:id="Locatie" value="Locatie A" styleClass="picker">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <String fx:value="Locatie A"/>
                            <String fx:value="Locatie B"/>
                            <String fx:value="Locatie C"/>
                            <String fx:value="Locatie D"/>
                        </FXCollections>
                    </items>
                </ComboBox>
                <ComboBox fx:id="Rol" value="Rol" styleClass="picker">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <String fx:value="Manager"/>
                            <String fx:value="Supervisor"/>
                            <String fx:value="Werknemer"/>
                        </FXCollections>
                    </items>
                </ComboBox>
                <ComboBox fx:id="Team" value="Team B" styleClass="picker">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <String fx:value="Team A"/>
                            <String fx:value="Team B"/>
                            <String fx:value="Team C"/>
                            <String fx:value="Team D"/>
                        </FXCollections>
                    </items>
                </ComboBox>
                <ComboBox fx:id="Werknemer" value="Milan" styleClass="picker">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <String fx:value="Milan"/>
                            <String fx:value="Marte"/>
                            <String fx:value="Leandro"/>
                            <String fx:value="Charles"/>
                        </FXCollections>
                    </items>
                </ComboBox>
            </HBox>

            <GridPane hgap="16" maxHeight="Infinity" VBox.vgrow="ALWAYS">
                <columnConstraints>
                    <ColumnConstraints percentWidth="50"/>
                    <ColumnConstraints percentWidth="50"/>
                </columnConstraints>
                <rowConstraints>
                    <RowConstraints vgrow="ALWAYS" minHeight="0"/>
                </rowConstraints>

                <!-- Kolom 0 -->
                <VBox spacing="12" GridPane.columnIndex="0" GridPane.vgrow="ALWAYS">
                    <HBox minHeight="30" prefHeight="30" spacing="5" alignment="CENTER_LEFT">
                        <Label fx:id="titel_taken" text="Alle taken:" styleClass="card_subtitle"/>
                        <Region HBox.hgrow="ALWAYS"/>
                    </HBox>
                    <VBox styleClass="card" spacing="5" VBox.vgrow="ALWAYS">
                        <TextField promptText="zoeken..." styleClass="task-input"/>
                        <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                        <VBox fx:id="taken_container" styleClass="task-section" VBox.vgrow="ALWAYS">
                            <padding><Insets top="8" bottom="12"/></padding>
                        </VBox>
                    </VBox>
                </VBox>

                <!-- Kolom 1 -->
                <VBox spacing="12" GridPane.columnIndex="1" GridPane.vgrow="ALWAYS">
                    <Region minHeight="30" prefHeight="30"/>
                    <VBox styleClass="card" spacing="12">
                        <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                        <HBox alignment="CENTER_LEFT">
                            <Label text="Taak details:" styleClass="section-label"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="edit_button" text="edit" styleClass="edit-link"/>
                        </HBox>
                        <HBox alignment="CENTER_LEFT">
                            <Label text="Toegewezen aan: Milan Van Bellingen" styleClass="task-due-text"/>
                        </HBox>
                        <HBox alignment="CENTER_LEFT">
                            <Label text="Tegen 12:30" styleClass="task-due-text"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label text="Locatie 3" styleClass="task-location-link"/>
                        </HBox>
                        <TextField promptText="taak naam" styleClass="task-input"/>
                        <TextArea promptText="specificaties" prefRowCount="3" styleClass="task-input-area"/>
                    </VBox>
                    <VBox styleClass="card" spacing="4" VBox.vgrow="ALWAYS">
                        <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                        <Label fx:id="afgewerkte_taken_titel" styleClass="section-label"/>
                        <VBox fx:id="finished_task_container" spacing="4" styleClass="task-section" VBox.vgrow="ALWAYS">
                            <padding><Insets top="8"/></padding>
                        </VBox>
                    </VBox>
                </VBox>

            </GridPane>

        </VBox>
    </center>
</fx:root>