<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.geometry.Insets?>
<fx:root type="BorderPane" xmlns:fx="http://javafx.com/fxml">

    <center>
        <VBox spacing="12" VBox.vgrow="ALWAYS">

            <HBox alignment="CENTER_RIGHT" spacing="10" minHeight="20">
                <ComboBox fx:id="Locatie" value="LocatieA" styleClass="picker"/>
                <ComboBox fx:id="Team" value="Team B" styleClass="picker"/>
                <ComboBox fx:id="Werknemer" value="Milan" styleClass="picker"/>
            </HBox>

            <GridPane hgap="16" maxHeight="Infinity" VBox.vgrow="ALWAYS">
                <columnConstraints>
                    <ColumnConstraints percentWidth="50"/>
                    <ColumnConstraints percentWidth="50"/>
                </columnConstraints>
                <rowConstraints>
                    <RowConstraints vgrow="ALWAYS" minHeight="0"/>
                </rowConstraints>

                <!-- Kolom 0 -->
                <VBox spacing="12" GridPane.columnIndex="0" GridPane.vgrow="ALWAYS">
                    <HBox minHeight="30" prefHeight="30" alignment="CENTER_LEFT">
                        <Label fx:id="titel_taken" styleClass="card_subtitle"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <ComboBox fx:id="filter" value="filter" styleClass="picker"/>
                    </HBox>
                    <VBox styleClass="card" spacing="0" VBox.vgrow="ALWAYS">
                        <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                        <Label text="Belangrijk:" styleClass="section-label"/>
                        <VBox fx:id="belangrijk_container" styleClass="task-section" VBox.vgrow="ALWAYS">
                            <padding><Insets top="8" bottom="12"/></padding>
                        </VBox>
                        <Label text="Taken tegen vandaag:" styleClass="section-label"/>
                        <VBox fx:id="vandaag_container" spacing="4" styleClass="task-section" VBox.vgrow="ALWAYS">
                            <padding><Insets top="8" bottom="12"/></padding>
                        </VBox>
                        <Label text="Taken tegen morgen:" styleClass="section-label"/>
                        <VBox fx:id="morgen_container" spacing="4" styleClass="task-section" VBox.vgrow="ALWAYS">
                            <padding><Insets top="8" bottom="4"/></padding>
                        </VBox>
                    </VBox>
                </VBox>

                <!-- Kolom 1 -->
                <VBox spacing="12" GridPane.columnIndex="1" GridPane.vgrow="ALWAYS">
                    <Region minHeight="30" prefHeight="30"/>
                    <VBox styleClass="card" spacing="12">
                        <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                        <HBox alignment="CENTER_LEFT">
                            <Label text="Taak beschrijving:" styleClass="section-label"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="edit_button" text="edit" styleClass="edit-link"/>
                        </HBox>
                        <HBox alignment="CENTER_LEFT">
                            <Label text="Tegen 12:30" styleClass="task-due-text"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label text="Locatie 3" styleClass="task-location-link"/>
                        </HBox>
                        <TextField promptText="taak naam" styleClass="task-input"/>
                        <TextArea promptText="specificaties" prefRowCount="3" styleClass="task-input-area"/>
                    </VBox>
                    <VBox styleClass="card" spacing="4" VBox.vgrow="ALWAYS">
                        <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                        <Label fx:id="afgewerkte_taken_titel" styleClass="section-label"/>
                        <VBox fx:id="finished_task_container" spacing="4" styleClass="task-section" VBox.vgrow="ALWAYS">
                            <padding><Insets top="8"/></padding>
                        </VBox>
                    </VBox>
                </VBox>

            </GridPane>

        </VBox>
    </center>
</fx:root>