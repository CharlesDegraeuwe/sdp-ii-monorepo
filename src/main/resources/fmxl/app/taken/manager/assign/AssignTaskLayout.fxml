<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<fx:root type="BorderPane" xmlns:fx="http://javafx.com/fxml" stylesheets="@/css/tasks.css">

    <center>
        <VBox spacing="16" maxWidth="850" alignment="TOP_LEFT">
            <padding><Insets top="8" right="8" bottom="8" left="8"/></padding>

           <HBox alignment="CENTER">
               <Label text="Taken Toewijzen:" styleClass="card_subtitle"/>
               <Region HBox.hgrow="ALWAYS"/>
               <HBox alignment="CENTER_RIGHT" spacing="10" minHeight="20">
                   <ComboBox fx:id="Locatie" value="Locatie A" styleClass="picker"/>
                   <ComboBox fx:id="Team" value="Team B" styleClass="picker"/>
                   <ComboBox fx:id="Werknemer" value="Milan" styleClass="picker"/>
               </HBox>
           </HBox>

            <HBox spacing="16">
                <VBox styleClass="card" spacing="8" HBox.hgrow="ALWAYS">
                    <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                    <Label text="Taken:" styleClass="section-label"/>
                    <VBox fx:id="taskListContainer" spacing="8" styleClass="task-section"/>
                </VBox>

                <VBox spacing="12" HBox.hgrow="ALWAYS">
                    <VBox styleClass="card" spacing="8" VBox.vgrow="ALWAYS">
                        <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                        <Label text="Teamleden:" styleClass="section-label"/>
                        <VBox fx:id="memberListContainer" spacing="6" styleClass="task-section"/>
                    </VBox>
                    <Button fx:id="assignButton" text="Wijs Taak Toe" styleClass="create-task-btn" maxWidth="Infinity"/>
                </VBox>
            </HBox>
        </VBox>
    </center>
</fx:root>