<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<fx:root type="VBox" spacing="12" xmlns:fx="http://javafx.com/fxml" stylesheets="@/css/planning.css">

    <!-- Shifts today card -->
    <VBox styleClass="card" spacing="10">
        <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>
        <HBox alignment="CENTER" spacing="8">
            <Button fx:id="btnPrevDay" text="‹" styleClass="btn_icon"/>
            <Label fx:id="lblDag" text="2 December 2025" styleClass="card_title" HBox.hgrow="ALWAYS" alignment="CENTER"/>
            <Button fx:id="btnNextDay" text="›" styleClass="btn_icon"/>
        </HBox>
        <Label text="Shiften vandaag:" styleClass="sidebar_section_label"/>
        <VBox fx:id="shiftsTodayContainer" spacing="6"/>
    </VBox>

    <!-- Shift tasks card -->
    <VBox styleClass="card" spacing="10" VBox.vgrow="ALWAYS">
        <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>
        <Label text="Shift taken:" styleClass="card_title"/>
        <Label text="Onafgewerkte Taken:" styleClass="sidebar_section_label"/>
        <VBox fx:id="unfinishedContainer" spacing="6"/>
        <Label text="Afgewerkte Taken:" styleClass="sidebar_section_label"/>
        <VBox fx:id="finishedContainer" spacing="6"/>
    </VBox>

</fx:root>