<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<fx:root type="BorderPane" xmlns:fx="http://javafx.com/fxml" styleClass="page" stylesheets="@/css/planning.css">
    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="scroll-pane">
            <content>
                <VBox spacing="20">
                    <padding><Insets top="20" right="40" bottom="30" left="40"/></padding>

                    <!-- Toolbar: views + navigatie -->
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <!-- View toggles -->
                        <HBox styleClass="toggle-groep" spacing="0">
                            <Button fx:id="maandKnop" text="Maand" onAction="#toonMaand" styleClass="toggle-knop-actief"/>
                            <Button fx:id="weekKnop" text="Week" onAction="#toonWeek" styleClass="toggle-knop"/>
                            <Button fx:id="dagKnop" text="Dag" onAction="#toonDag" styleClass="toggle-knop"/>
                        </HBox>

                        <Region HBox.hgrow="ALWAYS"/>

                        <!-- Navigatie -->
                        <Button fx:id="vorigeKnop" text="‹" onAction="#vorigePeriode" styleClass="nav-knop"/>
                        <Label fx:id="periodeLabel" text="..." styleClass="periode-label"/>
                        <Button fx:id="volgendeKnop" text="›" onAction="#volgendePeriode" styleClass="nav-knop"/>

                        <Region HBox.hgrow="ALWAYS"/>

                        <!-- Vandaag knop -->
                        <Button text="Vandaag" onAction="#naarVandaag" styleClass="vandaag-knop"/>
                    </HBox>

                    <!-- Kalender container -->
                    <VBox fx:id="kalenderContainer" spacing="0" styleClass="kalender-container"/>

                    <!-- Detail panel (dag detail) -->
                    <VBox fx:id="detailPanel" spacing="10" styleClass="detail-panel" visible="false" managed="false">
                        <Label fx:id="detailTitel" text="" styleClass="detail-titel"/>
                        <VBox fx:id="detailLijst" spacing="6"/>
                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>
</fx:root>