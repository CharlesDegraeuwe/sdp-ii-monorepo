<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.geometry.Insets?>
<?import javafx.collections.FXCollections?>
<fx:root type="VBox" xmlns:fx="http://javafx.com/fxml" styleClass="task_root" stylesheets="@/css/locaties.css">
    <GridPane hgap="10" vgap="10">
        <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
        <columnConstraints>
            <ColumnConstraints percentWidth="70"/>
            <ColumnConstraints percentWidth="30"/>
        </columnConstraints>

        <VBox GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="card">
            <HBox styleClass="card_header" alignment="CENTER_LEFT">
                <padding><Insets top="5" right="25" bottom="5" left="25"/></padding>
                <Label text="Alle locaties" fx:id="page_title" styleClass="page_title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox alignment="CENTER" spacing="15">
                    <TextField fx:id="zoekField" promptText="Zoek op naam of locatie..." prefWidth="300"/>
                    <ComboBox fx:id="statusDropdown" value="Toegewezen" styleClass="picker">
                        <items>
                            <FXCollections fx:factory="observableArrayList">
                                <String fx:value="Toegewezen"/>
                                <String fx:value="Niet toegewezen"/>
                            </FXCollections>
                        </items>
                    </ComboBox>
                </HBox>
            </HBox>
            <TableView fx:id="locatieTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="naamCol" text="Naam" prefWidth="120"/>
                    <TableColumn fx:id="locatieCol" text="Locatie" prefWidth="200"/>
                    <TableColumn fx:id="capCol" text="Capaciteit" prefWidth="100"/>
                    <TableColumn fx:id="statusCol" text="Status" prefWidth="100"/>
                </columns>
            </TableView>
            <HBox alignment="CENTER_LEFT">
                <padding><Insets top="15" right="20" bottom="15" left="20"/></padding>

                <Button fx:id="btnNieuw" text="+ Maak site aan" onAction="#handleNieuw" styleClass="btn-success"/>
            </HBox>

        </VBox>
        <VBox GridPane.columnIndex="1" GridPane.rowIndex="0" styleClass="card" VBox.vgrow="ALWAYS">
            <VBox spacing="15" VBox.vgrow="ALWAYS">
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

                <Label text="Site-info" style="-fx-font-weight: bold; -fx-font-size: 16px;"/>

                <VBox spacing="5">
                    <Label text="Naam:" style="-fx-text-fill: gray;"/>
                    <Label fx:id="lblDetailNaam" text="Selecteer een locatie..." style="-fx-font-size: 14px;"/>
                    <TextField fx:id="txtDetailNaam" visible="false" managed="false"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="Locatie/Adres:" style="-fx-text-fill: gray;"/>
                    <Label fx:id="lblDetailLocatie" text="-" wrapText="true"/>
                    <TextField fx:id="txtDetailLocatie" visible="false" managed="false"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="Capaciteit:" style="-fx-text-fill: gray;"/>
                    <Label fx:id="lblDetailCapaciteit" text="-"/>
                    <TextField fx:id="txtDetailCapaciteit" visible="false" managed="false"/>
                </VBox>

                <Label text="Status" style="-fx-font-weight: bold; -fx-font-size: 16px;">
                    <VBox.margin><Insets top="10"/></VBox.margin>
                </Label>
                <VBox spacing="5">
                    <Label fx:id="lblDetailStatus" text="-"/>
                    <ComboBox fx:id="cmbDetailStatus" visible="false" managed="false" prefWidth="150"/>
                </VBox>
            </VBox> <HBox spacing="10" alignment="CENTER_RIGHT" style="-fx-background-color: #f8f9fa;">
            <padding><Insets top="15" right="20" bottom="15" left="20"/></padding>
            <Button fx:id="btnWijzig" text="Wijzig" onAction="#handleWijzig" disable="true" styleClass="btn-secondary"/>
            <Button fx:id="btnVerwijder" text="Verwijder" onAction="#handleVerwijder" disable="true" styleClass="btn-danger"/>
        </HBox>

        </VBox> </GridPane>
</fx:root>