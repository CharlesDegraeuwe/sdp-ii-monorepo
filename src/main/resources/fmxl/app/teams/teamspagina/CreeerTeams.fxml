<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import org.kordamp.ikonli.javafx.FontIcon?>
<fx:root type="VBox" xmlns:fx="http://javafx.com/fxml"
         styleClass="root-container"
         stylesheets="@/css/teams.css">

    <!-- Top bar -->
    <HBox styleClass="top-bar">
        <Label text="Create team:" styleClass="page-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <ComboBox fx:id="filter" value="Filter op locatie" styleClass="picker"/>
    </HBox>

    <!-- Main card -->
    <HBox styleClass="main-card">

        <VBox styleClass="left-pane" HBox.hgrow="ALWAYS">
            <Label text="Basis Informatie:" styleClass="section-title"/>
            <TextField fx:id="nameField" promptText="naam" styleClass="input-field"/>
            <TextArea fx:id="descriptionField" promptText="beschrijving" styleClass="input-area" wrapText="true"/>
            <TextField fx:id="teamIdField" promptText="team id" styleClass="input-field"/>
            <HBox styleClass="dropdown-row">
                <ComboBox fx:id="managerCombo" promptText="manager" styleClass="picker" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                <ComboBox fx:id="plantCombo" promptText="locatie" styleClass="picker" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            </HBox>
            <Button fx:id="createTeamBtn" text="creëer team" styleClass="create-btn" maxWidth="Infinity"/>
        </VBox>

        <!-- Divider -->
        <Separator orientation="VERTICAL" styleClass="divider">
            <HBox.margin><Insets left="24" right="24"/></HBox.margin>
        </Separator>

        <!-- RIGHT: Members -->
        <VBox styleClass="right-pane" HBox.hgrow="ALWAYS">

            <!-- Header -->
            <HBox styleClass="members-header" alignment="CENTER_LEFT">
                <Label text="Leden:" styleClass="section-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <VBox styleClass="create-employee-box" alignment="CENTER">
                    <Button fx:id="createEmployeeBtn" text="+" styleClass="icon-btn-lg"/>
                    <Label text="creëer medewerkers" styleClass="icon-label"/>
                </VBox>
            </HBox>

            <!-- Search -->
            <HBox styleClass="search-bar" alignment="CENTER_LEFT">
                <TextField fx:id="searchField" promptText="zoek medewerkers" styleClass="search-input" HBox.hgrow="ALWAYS"/>
                <FontIcon iconLiteral="mdmz-search" iconSize="20" iconColor="black"/>
            </HBox>

            <!-- Employee rows -->
            <HBox styleClass="employee-row" alignment="CENTER_LEFT">
                <Label text="Medewerker" styleClass="employee-name" HBox.hgrow="ALWAYS"/>
                <Region HBox.hgrow="ALWAYS"/>
                <CheckBox text="supervisor" styleClass="supervisor-check"/>
                <Button text="+" styleClass="icon-btn-sm"/>
            </HBox>

            <HBox styleClass="employee-row" alignment="CENTER_LEFT">
                <Label text="Medewerker" styleClass="employee-name" HBox.hgrow="ALWAYS"/>
                <Region HBox.hgrow="ALWAYS"/>
                <CheckBox text="supervisor" styleClass="supervisor-check"/>
                <Button text="+" styleClass="icon-btn-sm"/>
            </HBox>

            <HBox styleClass="employee-row" alignment="CENTER_LEFT">
                <Label text="Medewerker" styleClass="employee-name" HBox.hgrow="ALWAYS"/>
                <Region HBox.hgrow="ALWAYS"/>
                <CheckBox text="supervisor" styleClass="supervisor-check"/>
                <Button text="+" styleClass="icon-btn-sm"/>
            </HBox>

            <HBox styleClass="employee-row" alignment="CENTER_LEFT">
                <Label text="Medewerker" styleClass="employee-name" HBox.hgrow="ALWAYS"/>
                <Region HBox.hgrow="ALWAYS"/>
                <CheckBox text="supervisor" styleClass="supervisor-check"/>
                <Button text="+" styleClass="icon-btn-sm"/>
            </HBox>

            <HBox styleClass="employee-row" alignment="CENTER_LEFT">
                <Label text="Medewerker" styleClass="employee-name" HBox.hgrow="ALWAYS"/>
                <Region HBox.hgrow="ALWAYS"/>
                <CheckBox text="supervisor" styleClass="supervisor-check"/>
                <Button text="+" styleClass="icon-btn-sm"/>
            </HBox>

            <HBox styleClass="employee-row" alignment="CENTER_LEFT">
                <Label text="Medewerker" styleClass="employee-name" HBox.hgrow="ALWAYS"/>
                <Region HBox.hgrow="ALWAYS"/>
                <CheckBox text="supervisor" styleClass="supervisor-check"/>
                <Button text="+" styleClass="icon-btn-sm"/>
            </HBox>

        </VBox>
    </HBox>
</fx:root>
