<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<fx:root type="VBox" xmlns:fx="http://javafx.com/fxml" styleClass="root-container">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <!-- Page title -->
    <Label text="Teams:" styleClass="page-title"/>

    <!-- Main card -->
    <HBox styleClass="main-card" spacing="24" VBox.vgrow="ALWAYS">

        <!-- LEFT: Teams list -->
        <VBox spacing="12" HBox.hgrow="ALWAYS" maxWidth="340">
            <Label text="Teams:" styleClass="section-title"/>
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background-color: transparent; -fx-border-color: transparent;">
                <VBox fx:id="teamsList" spacing="8"/>
            </ScrollPane>
        </VBox>

        <!-- Divider -->
        <Separator orientation="VERTICAL" styleClass="divider"/>

        <!-- RIGHT: Members list -->
        <VBox spacing="12" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="members-header">
                <Label text="Leden:" styleClass="section-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <VBox styleClass="create-employee-box">
                    <Button text="+" styleClass="icon-btn-lg" fx:id="addMemberBtn"/>
                    <Label text="voeg leden toe" styleClass="icon-label"/>
                </VBox>
            </HBox>
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background-color: transparent; -fx-border-color: transparent;">
                <VBox fx:id="membersList" spacing="8"/>
            </ScrollPane>
        </VBox>

    </HBox>
</fx:root>