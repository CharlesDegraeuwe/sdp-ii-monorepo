<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<fx:root type="VBox" xmlns="http://javafx.com/javafx"
         xmlns:fx="http://javafx.com/fxml"
         spacing="12">
    <padding>
        <Insets top="16" right="16" bottom="16" left="16"/>
    </padding>
    

    <Label fx:id="naam" styleClass="user-detail-name"/>
    <Label fx:id="email" styleClass="user-detail-value"/>
    <Label fx:id="telefoon" styleClass="user-detail-value"/>

    <Separator/>

    <Label fx:id="status" styleClass="user-detail-value"/>

    <Region VBox.vgrow="ALWAYS"/>

    <Button fx:id="demoteBtn" text="demote" styleClass="btn-danger" maxWidth="Infinity"/>
    <Button fx:id="blockBtn" text="block employee" styleClass="btn-outline" maxWidth="Infinity"/>
</fx:root>