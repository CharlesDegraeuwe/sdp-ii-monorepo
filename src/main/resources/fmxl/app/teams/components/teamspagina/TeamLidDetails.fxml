<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<fx:root type="VBox" xmlns="http://javafx.com/javafx"
         xmlns:fx="http://javafx.com/fxml"
         spacing="16" styleClass="popup-container">
    <padding>
        <Insets top="24" right="24" bottom="24" left="24"/>
    </padding>

    <Label fx:id="naam" styleClass="popup-title"/>

    <VBox spacing="8">
        <Label text="Email" styleClass="popup-label"/>
        <Label fx:id="email" styleClass="popup-value"/>
    </VBox>

    <VBox spacing="8">
        <Label text="Telefoon" styleClass="popup-label"/>
        <Label fx:id="telefoon" styleClass="popup-value"/>
    </VBox>

    <VBox spacing="8">
        <Label text="Rol" styleClass="popup-label"/>
        <Label fx:id="rol" styleClass="popup-value"/>
    </VBox>
</fx:root>