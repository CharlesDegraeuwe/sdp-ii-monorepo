<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<fx:root type="BorderPane" xmlns:fx="http://javafx.com/fxml" styleClass="page" stylesheets="@/css/notificaties.css">

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="scroll-pane">
            <content>
                <VBox spacing="20" alignment="TOP_CENTER">
                    <padding><Insets top="20" right="40" bottom="30" left="40"/></padding>

                    <!-- Filter knoppen -->
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Button fx:id="allesKnop" text="Alles" onAction="#filterAlles" styleClass="filter-knop-actief"/>
                        <Button fx:id="werkKnop" text="Werk" onAction="#filterWerk" styleClass="filter-knop"/>
                        <Button fx:id="afwezigheidKnop" text="Afwezigheid" onAction="#filterAfwezigheid" styleClass="filter-knop"/>
                        <Button fx:id="verlofKnop" text="Verlof" onAction="#filterVerlof" styleClass="filter-knop"/>
                    </HBox>

                    <!-- Ongelezen sectie -->
                    <VBox fx:id="ongelezenSectie" spacing="10">
                        <Label text="Ongelezen:" styleClass="sectie-label"/>
                        <VBox fx:id="ongelezenLijst" spacing="8"/>
                    </VBox>

                    <!-- Alle notificaties sectie -->
                    <VBox spacing="10">
                        <Label text="Alle notificaties:" styleClass="sectie-label"/>
                        <VBox fx:id="alleLijst" spacing="8"/>
                    </VBox>

                    <Label fx:id="leegLabel" text="Geen notificaties." styleClass="leeg-label" visible="false" managed="false"/>

                </VBox>
            </content>
        </ScrollPane>
    </center>

</fx:root>