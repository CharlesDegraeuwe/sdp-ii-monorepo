<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<fx:root type="VBox" spacing="0" xmlns:fx="http://javafx.com/fxml">
    <ScrollPane fx:id="scrollPane" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                VBox.vgrow="ALWAYS" styleClass="scroll-pane">
        <VBox fx:id="item_container" spacing="5">
            <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
        </VBox>
    </ScrollPane>
    <HBox fx:id="footer" alignment="CENTER" styleClass="notif_footer">
        <Label fx:id="footerLabel" text="Bekijk alle notificaties" styleClass="notif_footer_label"/>
    </HBox>
</fx:root>
