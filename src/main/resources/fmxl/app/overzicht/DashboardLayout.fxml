<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<fx:root type="BorderPane" xmlns:fx="http://javafx.com/fxml"  stylesheets="@/css/dashboard.css"
         styleClass="dashboard_root">

    <center>
        <HBox styleClass="dashboard_outer" spacing="16">
            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

            <!-- LINKER KOLOM -->
            <VBox styleClass="dashboard_left" spacing="16" HBox.hgrow="ALWAYS">

                <!-- Snelle Acties -->
                <VBox spacing="12">
                    <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                    <Label text="Snelle Acties" styleClass="card_title"/>
                    <GridPane hgap="10" vgap="10" styleClass="card" fx:id="quick_actions" id="quick_actions">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="50"/>
                            <ColumnConstraints percentWidth="50"/>
                        </columnConstraints>

                        <HBox styleClass="action_btn" spacing="10" alignment="CENTER_LEFT" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <FontIcon iconLiteral="ion4-md-add-circle-outline" iconSize="16" styleClass="action_icon"/>
                            <Label text="Add Shifts" styleClass="action_label"/>
                        </HBox>

                        <HBox styleClass="action_btn" spacing="10" alignment="CENTER_LEFT" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <FontIcon iconLiteral="ion4-md-checkmark-circle-outline" iconSize="16" styleClass="action_icon"/>
                            <Label text="Assign Task" styleClass="action_label"/>
                        </HBox>

                        <HBox styleClass="action_btn" spacing="10" alignment="CENTER_LEFT" GridPane.columnIndex="0" GridPane.rowIndex="1">
                            <FontIcon iconLiteral="ion4-md-alert" iconSize="16" styleClass="action_icon_red"/>
                            <Label text="Report Absence" styleClass="action_label"/>
                        </HBox>

                        <HBox styleClass="action_btn" spacing="10" alignment="CENTER_LEFT" GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <FontIcon iconLiteral="ion4-md-calendar" iconSize="16" styleClass="action_icon"/>
                            <Label text="Plan Holiday" styleClass="action_label"/>
                        </HBox>
                    </GridPane>
                </VBox>

                <!-- Geplande Uren -->
                <VBox spacing="12" VBox.vgrow="ALWAYS">
                    <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                    <Label text="Geplande Uren" styleClass="card_title"/>
                    <VBox styleClass="card"/>
                </VBox>

            </VBox>

            <!-- RECHTER KOLOM -->
            <VBox styleClass="dashboard_right" spacing="16" prefWidth="360">

                <!-- Kalender + Notificaties -->
                <HBox spacing="16">

                    <!-- Kalender -->
                    <VBox styleClass="card" spacing="10" HBox.hgrow="ALWAYS">
                        <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Button fx:id="btnPrevMonth" text="‹" styleClass="btn_icon"/>
                            <Label fx:id="lblMonth" text="December" styleClass="card_title" HBox.hgrow="ALWAYS"/>
                            <Button fx:id="btnNextMonth" text="›" styleClass="btn_icon"/>
                        </HBox>
                        <GridPane fx:id="calendarGrid" hgap="6" vgap="6" alignment="CENTER"/>
                    </VBox>

                    <!-- Notificaties -->
                    <VBox styleClass="card" spacing="10" HBox.hgrow="ALWAYS">
                        <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                        <Label text="Notificaties" styleClass="card_title"/>
                        <HBox spacing="6">
                            <Button text="All" styleClass="tab_active"/>
                            <Button text="Tasks" styleClass="tab"/>
                            <Button text="Absence" styleClass="tab"/>
                        </HBox>
                        <VBox fx:id="notificatiesList" spacing="8"/>
                    </VBox>

                </HBox>

                <!-- Statistieken -->
                <VBox styleClass="card" spacing="12" VBox.vgrow="ALWAYS">
                    <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                    <Label text="Statistieken" styleClass="card_title"/>
                    <HBox spacing="16" VBox.vgrow="ALWAYS">

                        <!-- Open Taken -->
                        <VBox spacing="10" HBox.hgrow="ALWAYS">
                            <HBox spacing="6">
                                <Button text="Your Tasks" styleClass="tab_active"/>
                                <Button text="Team Tasks" styleClass="tab"/>
                            </HBox>
                            <VBox fx:id="takenList" spacing="8"/>
                        </VBox>

                        <!-- Afwezige leden -->
                        <VBox spacing="10" HBox.hgrow="ALWAYS">
                            <Label text="Absent Members" styleClass="card_subtitle"/>
                            <VBox fx:id="afwezigenList" spacing="8"/>
                        </VBox>

                    </HBox>

                    <!-- Plant Coverage -->
                    <VBox spacing="8">
                        <Label text="Plant Coverage" styleClass="card_subtitle"/>
                        <VBox fx:id="plantList" spacing="8"/>
                    </VBox>

                </VBox>

            </VBox>

        </HBox>
    </center>

</fx:root>
