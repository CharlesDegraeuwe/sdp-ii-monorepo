<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<fx:root type="BorderPane" xmlns:fx="http://javafx.com/fxml" stylesheets="@/css/dashboard.css" styleClass="dashboard_root">
    <center>
        <HBox styleClass="dashboard_outer" spacing="16">
            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

            <!-- LINKER KOLOM -->
            <VBox styleClass="dashboard_left" spacing="16" HBox.hgrow="ALWAYS" prefWidth="500">

                <Label text="Snelle Acties" styleClass="section_title"/>
                <GridPane styleClass="card" hgap="10" vgap="10" fx:id="quick_actions">
                    <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                    <columnConstraints>
                        <ColumnConstraints percentWidth="50"/>
                        <ColumnConstraints percentWidth="50"/>
                    </columnConstraints>
                    <HBox styleClass="action_btn" spacing="10" alignment="CENTER_LEFT" fx:id="add_shift" GridPane.columnIndex="0" GridPane.rowIndex="0">
                        <FontIcon iconLiteral="ion4-md-add-circle-outline" iconSize="16" styleClass="action_icon"/>
                        <Label text="Shift toevoegen" styleClass="action_label"/>
                    </HBox>
                    <HBox styleClass="action_btn" spacing="10" alignment="CENTER_LEFT" fx:id="assign_task" GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <FontIcon iconLiteral="ion4-md-checkmark-circle-outline" iconSize="16" styleClass="action_icon"/>
                        <Label text="Taak Toekennen" styleClass="action_label"/>
                    </HBox>
                    <HBox styleClass="action_btn" spacing="10" alignment="CENTER_LEFT" fx:id="report_absence" GridPane.columnIndex="0" GridPane.rowIndex="1">
                        <FontIcon iconLiteral="ion4-md-alert" iconSize="16" styleClass="action_icon_red"/>
                        <Label text="Meld Afwezigheid" styleClass="action_label"/>
                    </HBox>
                    <HBox styleClass="action_btn" spacing="10" alignment="CENTER_LEFT" fx:id="plan_holiday" GridPane.columnIndex="1" GridPane.rowIndex="1">
                        <FontIcon iconLiteral="ion4-md-calendar" iconSize="16" styleClass="action_icon"/>
                        <Label text="Plan Vakantie" styleClass="action_label"/>
                    </HBox>
                </GridPane>

                <!-- Geplande Uren -->
                <Label text="Geplande Uren" styleClass="section_title"/>
                <VBox styleClass="card" spacing="12" VBox.vgrow="ALWAYS">
                    <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                    <TableView fx:id="shiftsTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colDag" text="Dag" prefWidth="80"/>
                            <TableColumn fx:id="colNaam" text="Naam" prefWidth="150"/>
                            <TableColumn fx:id="colUren" text="Uren" prefWidth="120"/>
                            <TableColumn fx:id="colSite" text="Site" prefWidth="80"/>
                        </columns>
                    </TableView>
                </VBox>

            </VBox>

            <!-- RECHTER KOLOM -->
            <VBox styleClass="dashboard_right" HBox.hgrow="ALWAYS" spacing="16" prefWidth="500">

                <!-- Kalender + Notificaties naast elkaar -->
                <HBox spacing="16">

                    <!-- Kalender -->
                    <VBox spacing="16" HBox.hgrow="ALWAYS">
                        <Label text="Kalender" styleClass="section_title"/>
                        <VBox styleClass="card" fx:id="kalender_container" minHeight="230" maxHeight="230"/>
                    </VBox>

                    <!-- Notificaties -->
                    <VBox spacing="16" HBox.hgrow="ALWAYS">
                        <Label text="Notificaties" styleClass="section_title"/>
                        <VBox styleClass="card" fx:id="notifications_container" minHeight="230" maxHeight="230"/>

                    </VBox>

                </HBox>

                <HBox>

                    <!-- statistieken -->
                    <VBox spacing="16" HBox.hgrow="ALWAYS">
                        <Label text="Statistieken" styleClass="section_title"/>
                        <HBox spacing="16">
                            <VBox styleClass="card" alignment="CENTER" fx:id="statistics">
                                <padding>
                                    <Insets top="10" right="10" bottom="10" left="10"/>
                                </padding>
                                <HBox spacing="16">

                                    <!-- Open Taken -->
                                    <VBox spacing="10" HBox.hgrow="ALWAYS">
                                        <HBox spacing="6">
                                            <Button text="Your Tasks" styleClass="tab_active"/>
                                            <Button text="Team Tasks" styleClass="tab"/>
                                        </HBox>
                                        <VBox fx:id="takenList" spacing="8"/>
                                    </VBox>

                                </HBox>
                            </VBox>
                            <VBox styleClass="card" spacing="10" VBox.vgrow="ALWAYS">
                                <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                                <HBox spacing="6">
                                    <Button text="All" styleClass="tab_active"/>
                                    <Button text="Tasks" styleClass="tab"/>
                                    <Button text="Absence" styleClass="tab"/>
                                </HBox>
                                <VBox fx:id="absense" spacing="8"/>
                            </VBox>
                        </HBox>

                    </VBox>


                </HBox>

                <!-- Statistieken -->
                <Label text="Locatie info" styleClass="section_title"/>
                <VBox styleClass="card" spacing="12" VBox.vgrow="ALWAYS">


                </VBox>

            </VBox>

        </HBox>
    </center>
</fx:root>
