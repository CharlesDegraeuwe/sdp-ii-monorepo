<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<fx:root type="BorderPane"
         xmlns:fx="http://javafx.com/fxml"
         stylesheets="@/css/dashboard.css">

    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll_pane">
            <content>

                <VBox spacing="20" styleClass="dashboard_content">
                    <padding>
                        <Insets top="20" right="20" bottom="20" left="20"/>
                    </padding>

                    <!-- ===================================================== -->
                    <!-- QUICK ACTIONS -->
                    <!-- ===================================================== -->
                    <VBox styleClass="card" spacing="16">
                        <padding>
                            <Insets top="20" right="20" bottom="20" left="20"/>
                        </padding>

                        <Label text="Quick actions:" styleClass="card_title"/>

                        <GridPane hgap="12" vgap="12">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="50"/>
                                <ColumnConstraints percentWidth="50"/>
                            </columnConstraints>

                            <Button fx:id="btnSeeShifts"
                                    text="See Shifts"
                                    styleClass="btn_quick"
                                    GridPane.columnIndex="0"
                                    GridPane.rowIndex="0"/>

                            <Button fx:id="btnCreateTask"
                                    text="Create Task"
                                    styleClass="btn_quick"
                                    GridPane.columnIndex="1"
                                    GridPane.rowIndex="0"/>

                            <Button fx:id="btnReportAbsence"
                                    text="Report Absence"
                                    styleClass="btn_quick"
                                    GridPane.columnIndex="0"
                                    GridPane.rowIndex="1"/>

                            <Button fx:id="btnPlanHoliday"
                                    text="Plan Holiday"
                                    styleClass="btn_quick"
                                    GridPane.columnIndex="1"
                                    GridPane.rowIndex="1"/>
                        </GridPane>
                    </VBox>


                    <!-- ===================================================== -->
                    <!-- MAIN GRID -->
                    <!-- ===================================================== -->
                    <GridPane hgap="20" vgap="20">

                        <columnConstraints>
                            <!-- Links groot -->
                            <ColumnConstraints percentWidth="50" hgrow="ALWAYS"/>
                            <!-- Midden -->
                            <ColumnConstraints percentWidth="25"/>
                            <!-- Rechts -->
                            <ColumnConstraints percentWidth="25"/>
                        </columnConstraints>

                        <!-- ================================================= -->
                        <!-- SCHEDULED HOURS (links, 2 rows hoog) -->
                        <!-- ================================================= -->
                        <VBox styleClass="card"
                              spacing="12"
                              GridPane.columnIndex="0"
                              GridPane.rowIndex="0"
                              GridPane.rowSpan="2"
                              GridPane.vgrow="ALWAYS">

                            <padding>
                                <Insets top="20" right="20" bottom="20" left="20"/>
                            </padding>

                            <HBox alignment="CENTER_LEFT">
                                <Label text="Scheduled Hours:" styleClass="card_title"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button text="Team shifts"
                                        styleClass="dropdown_button"/>
                            </HBox>

                            <!-- Lijstcontainer -->
                            <VBox fx:id="scheduledList"
                                  spacing="10"
                                  VBox.vgrow="ALWAYS"/>
                        </VBox>


                        <!-- ================================================= -->
                        <!-- CALENDAR (rechts boven links) -->
                        <!-- ================================================= -->
                        <VBox styleClass="card"
                              spacing="16"
                              GridPane.columnIndex="1"
                              GridPane.rowIndex="0">

                            <padding>
                                <Insets top="20" right="20" bottom="20" left="20"/>
                            </padding>

                            <Label text="Calendar:" styleClass="card_title"/>

                            <HBox alignment="CENTER" spacing="10">
                                <Button fx:id="btnPrevMonth"
                                        text="‹"
                                        styleClass="btn_icon"/>

                                <Label fx:id="lblMonth"
                                       text="December"
                                       styleClass="month_label"/>

                                <Button fx:id="btnNextMonth"
                                        text="›"
                                        styleClass="btn_icon"/>
                            </HBox>

                            <GridPane fx:id="calendarGrid"
                                      hgap="6"
                                      vgap="6"/>
                        </VBox>


                        <!-- ================================================= -->
                        <!-- NOTIFICATIONS (rechts boven rechts) -->
                        <!-- ================================================= -->
                        <VBox styleClass="card"
                              spacing="16"
                              GridPane.columnIndex="2"
                              GridPane.rowIndex="0">

                            <padding>
                                <Insets top="20" right="20" bottom="20" left="20"/>
                            </padding>

                            <Label text="Notifications:" styleClass="card_title"/>

                            <HBox spacing="10">
                                <Button text="All" styleClass="tab_active"/>
                                <Button text="Tasks" styleClass="tab"/>
                                <Button text="Absence" styleClass="tab"/>
                            </HBox>

                            <VBox fx:id="notificationsList"
                                  spacing="10"
                                  VBox.vgrow="ALWAYS"/>

                            <Hyperlink text="see more"
                                       styleClass="see_more_link"/>
                        </VBox>


                        <!-- ================================================= -->
                        <!-- OPEN TASKS -->
                        <!-- ================================================= -->
                        <VBox styleClass="card"
                              spacing="12"
                              GridPane.columnIndex="1"
                              GridPane.rowIndex="1">

                            <padding>
                                <Insets top="20" right="20" bottom="20" left="20"/>
                            </padding>

                            <HBox alignment="CENTER_LEFT">
                                <Label text="Open Tasks:" styleClass="card_title"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button text="Team A" styleClass="dropdown_button"/>
                            </HBox>

                            <VBox fx:id="openTasksList" spacing="8"/>

                            <Hyperlink text="see more"
                                       styleClass="see_more_link"/>
                        </VBox>


                        <!-- ================================================= -->
                        <!-- ABSENT TEAM MEMBERS -->
                        <!-- ================================================= -->
                        <VBox styleClass="card"
                              spacing="12"
                              GridPane.columnIndex="2"
                              GridPane.rowIndex="1">

                            <padding>
                                <Insets top="20" right="20" bottom="20" left="20"/>
                            </padding>

                            <HBox alignment="CENTER_LEFT">
                                <Label text="Absent Team Members:" styleClass="card_title"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button text="Team A" styleClass="dropdown_button"/>
                            </HBox>

                            <VBox fx:id="absentList" spacing="8"/>

                            <Hyperlink text="see more"
                                       styleClass="see_more_link"/>
                        </VBox>


                        <!-- ================================================= -->
                        <!-- PLANT COVERAGE (onder Scheduled Hours, volle breedte midden+rechts) -->
                        <!-- ================================================= -->
                        <VBox styleClass="card"
                              spacing="16"
                              GridPane.columnIndex="1"
                              GridPane.rowIndex="2"
                              GridPane.columnSpan="2">

                            <padding>
                                <Insets top="20" right="20" bottom="20" left="20"/>
                            </padding>

                            <Label text="Plant Coverage:" styleClass="card_title"/>

                            <HBox spacing="20">

                                <!-- Chart -->
                                <VBox fx:id="plantChartContainer"
                                      spacing="8"
                                      HBox.hgrow="ALWAYS"/>

                                <!-- Teams -->
                                <VBox spacing="10">
                                    <Label text="Plant Teams:"
                                           styleClass="sub_title"/>
                                    <VBox fx:id="plantTeamsList"
                                          spacing="8"/>
                                </VBox>

                            </HBox>
                        </VBox>

                    </GridPane>

                </VBox>

            </content>
        </ScrollPane>
    </center>

</fx:root>