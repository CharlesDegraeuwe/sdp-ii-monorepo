<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<fx:root type="BorderPane" xmlns:fx="http://javafx.com/fxml"
         styleClass="page"
         stylesheets="@/css/dashboard.css ,@/css/absense.css">
    <center>
        <VBox spacing="16" alignment="TOP_CENTER">
            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

            <Label fx:id="foutLabel" styleClass="error-label" visible="false" managed="false"/>
            <Label fx:id="succesLabel" styleClass="success-label" visible="false" managed="false"/>

            <!-- Toggle -->
            <HBox alignment="CENTER">
                <HBox styleClass="filter-container" spacing="2">
                    <Button fx:id="verlofKnop" text="Verlof aanvragen" onAction="#toonVerlof" styleClass="filter-knop-actief"/>
                    <Button fx:id="ziekteKnop" text="Ziekte melden" onAction="#toonZiekte" styleClass="filter-knop"/>
                    <Button fx:id="geschiedenisKnop" text="Geschiedenis" onAction="#toonGeschiedenis" styleClass="filter-knop"/>
                </HBox>
            </HBox>

            <!-- VERLOF -->
            <VBox fx:id="verlofCard" styleClass="card" spacing="20" maxWidth="800">
                <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
                <VBox fx:id="verlofBox" spacing="16">
                    <Label text="Verlof aanvragen" styleClass="card_title"/>
                    <HBox spacing="16">
                        <VBox spacing="4">
                            <Label text="Startdatum" styleClass="card_subtitle"/>
                            <DatePicker fx:id="verlofStartDatum" prefWidth="150"/>
                        </VBox>
                        <VBox spacing="4">
                            <Label text="Einddatum" styleClass="card_subtitle"/>
                            <DatePicker fx:id="verlofEindDatum" prefWidth="150"/>
                        </VBox>
                    </HBox>
                    <VBox spacing="4">
                        <Label text="Type verlof" styleClass="card_subtitle"/>
                        <ComboBox fx:id="verlofTypeCombo" prefWidth="200" styleClass="team_picker"/>
                    </VBox>
                </VBox>
                <TextArea fx:id="extraUitlegArea" promptText="Extra toelichting (optioneel)..." prefHeight="80" styleClass="absense-textarea"/>
                <HBox alignment="CENTER">
                    <Button fx:id="indienKnop" text="Verlof aanvragen" onAction="#indienen" styleClass="absense-report-btn"/>
                </HBox>
            </VBox>

            <!-- ZIEKTE -->
            <VBox fx:id="ziekteCard" styleClass="card" spacing="20" maxWidth="800" visible="false" managed="false">
                <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
                <VBox fx:id="ziekteBox" spacing="16">
                    <Label text="Ziekte melden" styleClass="card_title"/>
                    <TextField fx:id="redenField" promptText="Reden voor afwezigheid..." styleClass="absense-input"/>
                    <HBox spacing="30">
                        <VBox spacing="12" HBox.hgrow="ALWAYS">
                            <Label text="Duur:" styleClass="card_title"/>
                            <HBox spacing="16">
                                <VBox spacing="4">
                                    <Label text="Startdatum" styleClass="card_subtitle"/>
                                    <DatePicker fx:id="startDatumPicker" minWidth="130"/>
                                </VBox>
                                <VBox spacing="4">
                                    <Label text="Einddatum" styleClass="card_subtitle"/>
                                    <DatePicker fx:id="eindDatumPicker" minWidth="130"/>
                                </VBox>
                            </HBox>
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Label text="Hele dag" styleClass="card_subtitle"/>
                                <ToggleButton fx:id="heleDagToggle" styleClass="absense-toggle" selected="false"/>
                            </HBox>
                            <HBox fx:id="tijdBox" spacing="16" alignment="CENTER_LEFT">
                                <VBox spacing="4">
                                    <Label text="Starttijd" styleClass="card_subtitle"/>
                                    <HBox spacing="5" alignment="CENTER">
                                        <Spinner fx:id="startUurSpinner" prefWidth="55"/>
                                        <Label text=":" styleClass="card_subtitle"/>
                                        <Spinner fx:id="startMinuutSpinner" prefWidth="55"/>
                                    </HBox>
                                </VBox>
                                <VBox spacing="4">
                                    <Label text="Eindtijd" styleClass="card_subtitle"/>
                                    <HBox spacing="5" alignment="CENTER">
                                        <Spinner fx:id="eindUurSpinner" prefWidth="55"/>
                                        <Label text=":" styleClass="card_subtitle"/>
                                        <Spinner fx:id="eindMinuutSpinner" prefWidth="55"/>
                                    </HBox>
                                </VBox>
                            </HBox>
                        </VBox>
                        <VBox spacing="10" alignment="TOP_LEFT" minWidth="220">
                            <Label text="Upload ziektebriefje:" styleClass="card_title"/>
                            <VBox styleClass="upload-area" alignment="CENTER" spacing="8" minHeight="130">
                                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                                <Label text="⬆" styleClass="upload-icon"/>
                                <Label text="sleep bestanden hierheen" styleClass="card_subtitle"/>
                                <Label text="of" styleClass="card_subtitle"/>
                                <Button text="bladeren" onAction="#uploadCertificaat" styleClass="browse-btn"/>
                            </VBox>
                            <Label fx:id="certificaatLabel" text="" styleClass="card_subtitle"/>
                        </VBox>
                    </HBox>
                </VBox>
                <TextArea fx:id="ziekteExtraArea" promptText="Extra toelichting (optioneel)..." prefHeight="80" styleClass="absense-textarea"/>
                <HBox alignment="CENTER">
                    <Button text="Ziekte melden" onAction="#indienen" styleClass="absense-report-btn"/>
                </HBox>
            </VBox>

            <!-- GESCHIEDENIS -->
            <HBox fx:id="geschiedenisCard" spacing="16" maxWidth="900" visible="false" managed="false">

                <!-- Linker kolom: teamleden -->
                <VBox fx:id="teamledenPanel" spacing="10" minWidth="220" maxWidth="220" styleClass="card">
                    <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                    <Label text="Teamleden" styleClass="card_title"/>
                    <VBox fx:id="teamledenLijst" spacing="6"/>
                </VBox>

                <!-- Rechter kolom: geschiedenis van geselecteerde werknemer -->
                <VBox fx:id="geschiedenisDetail" spacing="10" HBox.hgrow="ALWAYS" styleClass="card">
                    <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                    <Label fx:id="geschiedenisTitel" text="Selecteer een teamlid" styleClass="card_title"/>
                    <VBox fx:id="geschiedenisLijst" spacing="8"/>
                </VBox>

            </HBox>

        </VBox>
    </center>
</fx:root>