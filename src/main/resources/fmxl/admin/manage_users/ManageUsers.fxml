<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Label?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<fx:root type="VBox" stylesheets="@/css/manageUsers.css" styleClass="page" spacing="20" xmlns:fx="http://javafx.com/fxml">


    <Label text="Mijn Team" styleClass="page-title"/>

    <Label fx:id="foutLabel" styleClass="error-label" visible="false" managed="false"/>

    <HBox spacing="10" styleClass="toolbar">
        <TextField fx:id="zoekField" promptText="Zoek op naam of email..." prefWidth="300"/>

        <ComboBox fx:id="statusFilterBox" promptText="Filter op status..." prefWidth="150"/>
    </HBox>

    <TableView fx:id="gebruikersTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="naamCol" text="Naam" prefWidth="120"/>
            <TableColumn fx:id="voornaamCol" text="Voornaam" prefWidth="120"/>
            <TableColumn fx:id="emailCol" text="Email" prefWidth="200"/>
            <TableColumn fx:id="rolCol" text="Rol" prefWidth="100"/>
            <TableColumn fx:id="statusCol" text="Status" prefWidth="100"/>
            <TableColumn fx:id="telefoonCol" text="Telefoonnummer" prefWidth="140"/>
        </columns>
    </TableView>

    <HBox spacing="15" alignment="CENTER_LEFT">
        <Button fx:id="btnActiveer" text="Activeer" onAction="#handleActiveer" styleClass="btn-activeer"/>
        <Button fx:id="btnDeactiveer" text="Deactiveer" onAction="#handleDeactiveer" styleClass="btn-deactiveer"/>
        <Button fx:id="btnBlokkeer" text="Blokkeer" onAction="#handleBlokkeer" styleClass="btn-blokkeer"/>
    </HBox>

</fx:root>